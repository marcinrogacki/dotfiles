!layout
URxvt*transparent: true
URxvt*shading: 15
URxvt*foreground: White
URxvt*background: Black
URxvt*scrollBar: false
URxvt*scrollBar_right: false
URxvt*scrollstyle: rxvt
! Correct fonts must be set. List of available fonts can be found by using
! command fc-list ("fc-list : family" will group by family). A fontviewer (AUR)
! software can be used to preview fonts.
! Know issues when font is inncorect:
! - Error message: "urxvt: unable to load base fontset, please specify a valid one using -fn, aborting."
! - Fonts are too bold and unreadable.
! - resize-font does not work with all fonts like DEC Terminal
URxvt*font: xft:DejaVu Sans Mono:pixelsize=18
! Enable when fonts are to wide (takes to much horizontal space).
!URxvt*letterSpace: -1
!Larger history limit
URxvt.saveLines: 1000000
! default includes confirm-paste (prompts on multiline / control chars); -confirm-paste disables that.
! clipboard - added to handle ctrl+shift+v to paste from browser
URxvt.perl-ext-common: default,-confirm-paste,clipboard,resize-font
!resize-font config
URxvt.resize-font.bigger: C-Up
URxvt.resize-font.smaller: C-Down
! Ease paste into urxvt from browser, nvim, etc
URxvt.keysym.Shift-Control-V: eval:paste_clipboard
URxvt.keysym.Shift-Control-P: eval:paste_primary
! Avoid urxvt to use ISO 14755 Unicode entry on Ctrl+Shift+ key chords. With
! iso14755 those chords are handled as “Unicode compose” input rather than
! normal bindings. That interfere with Shift-Control-V, Shift-Control-P sending
! unicode chars instead.
URxvt.iso14755: false
