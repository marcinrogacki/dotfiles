#!/usr/bin/env bash
# Sends a desktop notification and asks for approval only for risky commands.
# Safe/read-only commands are allowed silently.

input_json=$(cat)
echo "$input_json" >> /tmp/1
conversation_id=$(jq -r '(.conversation_id)' <<< "$input_json")
chat_db="`find $HOME/.cursor -name "$conversation_id" | grep chats`/store.db"

printf '%s\n' "sqlite3 \"$chat_db\" \"SELECT CAST(data AS TEXT) AS payload FROM blobs;\" | grep -a '\"role\":\"assistant\"' | tail -n 1" >> /tmp/cursor.log
sqlite3 "$chat_db" "SELECT CAST(data AS TEXT) AS payload FROM blobs;" \
    | grep -a '"role":"assistant"' \
    | tail -n 1 \
    >> /tmp/cursor.log

# Check whether tool need approval
if sqlite3 "$chat_db" "SELECT CAST(data AS TEXT) AS payload FROM blobs;" \
    | grep -a '"role":"assistant"' \
    | tail -n 1 \
    | grep -a -q "required_permissions"
then
  notify-send \
    --app-name="Cursor" \
    --icon="$HOME/.cursor/hooks/icon_32x32.png" \
    --urgency=critical \
    --expire-time=10000 \
    --category="dev.tool" \
    "Pending action" \
    "$message"
fi

exit 0
