{
    "version": 1,
    "hooks": {
        "preToolUse": [
            {
                "command": "./hooks/schedule-notify.sh"
            }
        ],
        "postToolUse": [
            {
                "command": "./hooks/cancel-notify.sh"
            }
        ],
        "postToolUseFailure": [
            {
                "command": "./hooks/cancel-notify.sh"
            }
        ],
        "stop": [
            {
                "command": "./hooks/notify-stop.sh"
            }
        ],
        "preCompact": [
            {
                "command": "./hooks/notify-context-compact.sh"
            }
        ]
    }
}
